# Homebrew shellenv: detect prefix (Apple Silicon vs Intel) and load it.
if [[ -x /opt/homebrew/bin/brew ]]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
elif [[ -x /usr/local/bin/brew ]]; then
    eval "$(/usr/local/bin/brew shellenv)"
fi

# source antigen location (under the active Homebrew prefix)
source "${HOMEBREW_PREFIX:-/opt/homebrew}/share/antigen/antigen.zsh"

# load oh-my-zsh library
antigen init $HOME/.antigenrc

# Default editor
export EDITOR='vim'

# Starship prompt config
export STARSHIP_CONFIG="$HOME/.dotfiles/files/home/starship.toml"

# Aliases
source "$HOME/.dotfiles/files/home/zsh_aliases"

# Always enable colored `grep` output
export GREP_OPTIONS="--color=auto"

# Custom Path
export PATH="$PATH:$HOME/.composer/vendor/bin:$HOME/.config/composer/vendor/bin"
export PATH="$PATH:$HOME/.dotfiles/bin"
export PATH="$PATH:$HOME/bin:$HOME/.config/phpmon/bin:$HOME/.local/bin"

# mise - polyglot version manager (node, python, ruby, java, rust)
eval "$(mise activate zsh)"

# Zsh
export PATH="/usr/local/opt/ncurses/bin:$PATH"

# FZF
eval "$(fzf --zsh)"
source "$HOME/.dotfiles/files/home/fzf.sh"

# zoxide
eval "$(zoxide init zsh)"

# Per-machine overrides — keep this last so it can override anything above.
# ~/.zshrc.local is intentionally not tracked; use it for work secrets,
# host-specific PATH entries, proxies, API tokens, etc.
[ -f "$HOME/.zshrc.local" ] && source "$HOME/.zshrc.local"
