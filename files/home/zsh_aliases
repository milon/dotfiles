#!/bin/zsh

# zsh aliases

# weather
function weather() {
    curl "wttr.in/${1}"
}

# show and hide files
alias show-files="defaults write com.apple.finder AppleShowAllFiles YES; killall Finder /System/Library/CoreServices/Finder.app"
alias hide-files="defaults write com.apple.finder AppleShowAllFiles NO; killall Finder /System/Library/CoreServices/Finder.app"

# Base64
function encode() {
    echo -n "${1}" | base64
}
function decode() {
    echo -n "${1}" | base64 --decode
}

# Kill every process listening on a given port (lsof -t prints PIDs only).
function kill-port() {
    local port=$1
    if [[ -z $port ]]; then
        echo "usage: kill-port <port>" >&2
        return 1
    fi
    local pids
    pids=$(lsof -ti:"$port") || true
    if [[ -z $pids ]]; then
        echo "No process found on port $port"
        return 1
    fi
    echo "$pids" | xargs kill -9
    echo "Killed process(es) on port $port: $(echo "$pids" | tr '\n' ' ')"
}

# xh (httpie replacement, cli http client)
alias http="xh"

# nvim to vim
alias vim="nvim"

# bat (cat on steroids)
alias cat="bat --paging=never --theme=Coldark-Dark --plain"

# eza (ls on steroids)
alias ls="eza --color=always --icons=always --git"

# zoxide (cd on steroids)
alias cd="z"

# python
alias python="python3"

# laravel
alias art="php artisan" 
alias sail="sh $([ -f sail ] && echo sail || echo vendor/bin/sail)"
